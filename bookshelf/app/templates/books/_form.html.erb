<%= form_for :book, form_path, method: form_method do |form| %>
  <% if errors.keys.any? %>
    <div style="color: red">
      <h2>Error(s) prohibited this book from being saved:</h2>

      <ul>
        <% errors.each do |key, messages| %>
          <li><%= inflector.humanize(key) %>: <%= messages.join(", ") %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  
  <div>
    <%= form.label :author, style: "display: block" %>
    <%= form.text_field :author %>
  </div>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.submit form_submit %>
  </div>
<% end %>
