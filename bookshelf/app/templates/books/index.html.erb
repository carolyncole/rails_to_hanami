<p style="color: green"><%= flash[:notice] %></p>

<% content_for :title, "Books" %>

<h1>Welcome to the Bookshelf</h1>

<div id="books">
  <% books.each do |book| %>
    <div class="book">
      <%= render "book", book: book %>
      <p>
        <%= link_to "Show this book", routes.path(:book, id: book.id) %>
      </p>
    </div>
  <% end %>
</div>

<%= link_to "New book", routes.path(:new_book), class: "btn btn-primary" %>
